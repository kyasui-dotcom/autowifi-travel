{
  "name": "autowifi-travel-api",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "autowifi-travel-db",
      "database_id": "3f798287-8f47-4ea9-a0a4-eb22698a2dcb"
    }
  ]
}
